<?xml version="1.0" encoding="UTF-8" ?>
<!--  /mybatisstudy/src/mapper/StudentMapper3.xml -->
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="student3">
  <select id="count" resultType="int">
     select count(*) from student
  </select>
  <select id="list" resultType="Student">
     select * from student
  </select>
  <select id="selectgrade" resultType="Student" 
          parameterType="int" >
     select * from student where grade=#{value}
  </select>
   <select id="selectname" resultType="Student" parameterType="string">
     select * from student where name like '${value}%'
  </select>
  <select id="selectgradegender" resultType="Student" 
                                  parameterType="map">
     select * from student where grade = #{grade}
                     and substr(jumin,7,1) in (#{gender1},#{gender2})
  </select> 
  <select id="selectall" resultType="Student" parameterType="map">
     select * from student
	 <trim prefix="where" prefixOverrides="AND || OR">
     	<if test="grade != null">and grade = #{grade}</if>
     	<if test="datas != null">and ${column} in 
     	  <foreach collection="datas" item="d" separator="," open="(" close=")">#{d}</foreach>
     	  </if>
     	<if test="name != null">and name like '${name}%'</if>
	 </trim>
  </select>

</mapper>