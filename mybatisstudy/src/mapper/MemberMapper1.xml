<?xml version="1.0" encoding="UTF-8" ?>
<!--  /mybatisstudy/src/mapper/MemberMapper1.xml -->
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="member"> <!-- 내부의 sql구문의 id값 : namespace.id속성값으로 호출됨 -->
	<select id="count" resultType="int"> <!--resultType :  sql구문 실행 후 전달되는 결과레코드의 타입 -->
		select count(*) from member
	</select>
	<select id="list" resultType="Member">
		select * from member
	</select>
	<select id="selectid" 	resultType="Member"	parameterType="string">
		select * from member  where id=#{value}
	</select>
	<select id="selectid2" 	resultType="Member"	parameterType="string">
		select * from member  where id like #{value}
	</select>
<!--
#{value} : 파라미터의 값 + 자료형.
		value: ad 이라 가정
		where id like %#{value}% => where id like %'ad'%  => 오류 발생 
${value} : 파라미터의 값의 치환     admin 
		value: ad 이라 가정
		where id like '%${value}%' => where id like '%ad%'  => 정상처리 
 -->	
	<select id="selectname"	resultType="Member"	parameterType="string">
		select * from member  where name like '%${value}%'
	</select>
	<select id="selectname2"	resultType="Member"	parameterType="map">
		select * from member  where name like '%${name}%' and gender=#{gender} 
	</select>
	
</mapper>